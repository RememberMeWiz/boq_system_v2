# Plan2Takeoff V2 — Backend Environment Variables
# Copy this file to backend/.env and fill in your values.
# DO NOT commit the filled-in .env to Git (it's in .gitignore).

# ── Supabase V2 Credentials ──────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key-here

# ── Optional: Google Gemini Vision API Key (for vision_parser.py OCR) ─
# Get this from: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-api-key-here

# ── Optional: Server Port ────────────────────────────────────────────
PORT=5000

# ── Optional: Flask secret key (for sessions/cookies if added later) ─
# FLASK_SECRET_KEY=change-me-to-a-random-string

